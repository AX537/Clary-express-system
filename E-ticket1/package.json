{
  "name": "e-ticketing-system",
  "version": "1.0.0",
  "description": "Backend REST API for E-Ticketing System with bus booking, QR code payments, and role-based access control",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "migrate": "node src/scripts/migrate.js",
    "migrate:rollback": "node src/scripts/migrate.js rollback",
    "seed": "node src/scripts/seed.js",
    "test:db": "node src/scripts/testConnection.js"
  },
  "keywords": [
    "e-ticketing",
    "bus-booking",
    "rest-api",
    "express",
    "mysql",
    "sequelize",
    "jwt",
    "qr-code"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.3.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "mysql2": "^3.6.5",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
